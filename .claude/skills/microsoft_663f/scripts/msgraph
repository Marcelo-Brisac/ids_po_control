#!/usr/bin/env bash
# msgraph — wrapper around the bundled Microsoft Graph CLI.
#
# Resolves the real script path so symlinks (e.g. /usr/local/bin/msgraph
# created by scripts/_install.sh) still locate .env and the bundled binary
# relative to this skill's scripts/ directory.
#
# Loads <skill-root>/.env into the environment so the platform-injected
# bearer token reaches the CLI. Accepts any of:
#   MSGRAPH_ACCESS_TOKEN  — preferred (this fork)
#   MICROSOFT_ACCESS_TOKEN — platform default (Nango microsoft provider)
#   ACCESS_TOKEN          — generic fallback
# whichever is non-empty is exported as MSGRAPH_ACCESS_TOKEN for the CLI.
set -euo pipefail

# Resolve real path (walk symlinks).
script_path="${BASH_SOURCE[0]}"
while [[ -L "$script_path" ]]; do
  link_dir="$(cd "$(dirname "$script_path")" && pwd)"
  script_path="$(readlink "$script_path")"
  [[ "$script_path" != /* ]] && script_path="$link_dir/$script_path"
done
SCRIPT_DIR="$(cd "$(dirname "$script_path")" && pwd)"
SKILL_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
ENV_FILE="$SKILL_ROOT/.env"
REFS_DIR="$SKILL_ROOT/references"

# Load .env into the environment (export every key).
if [[ -f "$ENV_FILE" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "$ENV_FILE"
  set +a
fi

# Normalize the token to MSGRAPH_ACCESS_TOKEN (the fork's primary env name).
TOKEN="${MSGRAPH_ACCESS_TOKEN:-${MICROSOFT_ACCESS_TOKEN:-${ACCESS_TOKEN:-}}}"
if [[ -n "$TOKEN" ]]; then
  export MSGRAPH_ACCESS_TOKEN="$TOKEN"
fi

# Auto-locate bundled offline indexes — the CLI's auto-detection looks in
# install-time locations that do not exist inside the sandbox, so without
# this every openapi-search / api-docs-search / sample-search fails on
# first invocation. Each var is only set if not already provided by the
# caller, so users can still override.
for var_db in \
  "MSGRAPH_INDEX_DB_PATH=graph-api-index.db" \
  "MSGRAPH_API_DOCS_DB_PATH=api-docs-index.db" \
  "MSGRAPH_SAMPLES_DB_PATH=samples-index.db"; do
  var="${var_db%%=*}"
  db="${var_db#*=}"
  if [[ -z "${!var:-}" && -f "$REFS_DIR/$db" ]]; then
    export "$var=$REFS_DIR/$db"
  fi
done

REAL_BIN="$SCRIPT_DIR/.bin"
if [[ ! -x "$REAL_BIN" ]]; then
  echo "msgraph: bundled binary not found at $REAL_BIN" >&2
  exit 1
fi

exec "$REAL_BIN" "$@"
