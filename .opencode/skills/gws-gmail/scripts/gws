#!/usr/bin/env bash
set -euo pipefail

# Thin gws wrapper for a Google Workspace skill.
# Sources .env (which sets GOOGLE_WORKSPACE_CLI_TOKEN), then execs the real
# gws binary. Auth is platform-managed via Nango — the agent never logs in.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="$SCRIPT_DIR/.env"

# Source the skill-scoped .env
if [ -f "$ENV_FILE" ]; then
  set -a
  source "$ENV_FILE"
  set +a
fi

[ -n "${GOOGLE_WORKSPACE_CLI_TOKEN:-}" ] || {
  echo "gws: GOOGLE_WORKSPACE_CLI_TOKEN not set in $ENV_FILE" >&2
  exit 1
}

# Find the real gws binary, skipping this wrapper
SELF="$(realpath "${BASH_SOURCE[0]}")"
GWS_BIN=""
while IFS= read -r -d: dir; do
  candidate="$dir/gws"
  if [ -x "$candidate" ] && [ "$(realpath "$candidate")" != "$SELF" ]; then
    GWS_BIN="$candidate"
    break
  fi
done <<< "$PATH:"

[ -n "$GWS_BIN" ] || { echo "gws: real gws binary not found in PATH" >&2; exit 1; }

exec "$GWS_BIN" "$@"
